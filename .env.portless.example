# Local HTTPS dev (portless) — copy to .env.portless and fill in secrets.
# `bun run dev:portless` reads this file and serves the web app at
# https://openkey.localhost and the API at https://api.openkey.localhost.
# WebAuthn requires HTTPS, which is why portless exists.

# Database
# Local dev uses in-process PGlite by default.
# For prod-parity testing, run `bun docker:up` and use:
# DATABASE_URL=postgresql://openkey:openkey@localhost:5432/openkey
DATABASE_URL=pglite:

# Ports — portless tunnels these and exposes them on https://*.localhost
API_PORT=3001
WEB_PORT=5173
ADMIN_PORT=5174

# Service URLs — point at the portless HTTPS endpoints, NOT the raw ports.
API_URL=https://api.openkey.localhost
WEB_URL=https://openkey.localhost
ADMIN_URL=https://admin.openkey.localhost
VITE_API_URL=https://api.openkey.localhost

# WebAuthn / Passkey
# RP ID is the apex of the portless host. Use `openkey.localhost` so the
# credential is bound to the dev host and works in this profile only.
WEBAUTHN_RP_ID=openkey.localhost
WEBAUTHN_ORIGIN=https://openkey.localhost

# Auth
BETTER_AUTH_SECRET=<generate-a-random-secret>
BETTER_AUTH_URL=https://api.openkey.localhost
CORS_ORIGIN=https://openkey.localhost,https://admin.openkey.localhost

# OAuth - Google (use the same client as dev or register a new one with the
# portless callback URLs)
GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>

# TEE Mode
TEE_MODE=development
DEV_SEALING_KEY=<32-byte-hex-key-for-local-dev>

# Email (Resend)
RESEND_API_KEY=<your-resend-api-key>

# Admin
OPENKEY_API_URL=https://api.openkey.localhost
ADMIN_API_KEY=your-secret-key
