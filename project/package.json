{
  "name": "openkey",
  "version": "1.0.0",
  "description": "Open-source authentication service combining WebAuthn with Ethereum key management",
  "private": true,
  "workspaces": ["backend", "frontend", "shared"],
  "scripts": {
    "dev": "docker-compose up",
    "build": "bun run build:shared && bun run build:backend && bun run build:frontend",
    "build:shared": "cd shared && bun run build",
    "build:backend": "cd backend && bun run build",
    "build:frontend": "cd frontend && bun run build",
    "test": "bun run test:unit && bun run test:integration",
    "test:unit": "bun run test:backend && bun run test:frontend",
    "test:backend": "cd backend && bun test",
    "test:frontend": "cd frontend && bun test",
    "test:integration": "cd tests && bun run integration",
    "test:e2e": "cd tests && bun run e2e",
    "lint": "bun run lint:backend && bun run lint:frontend",
    "lint:backend": "cd backend && bun run lint",
    "lint:frontend": "cd frontend && bun run lint",
    "install:all": "bun install && bun run install:backend && bun run install:frontend && bun run install:shared && bun run install:tests",
    "install:backend": "cd backend && bun install",
    "install:frontend": "cd frontend && bun install", 
    "install:shared": "cd shared && bun install",
    "install:tests": "cd tests && bun install",
    "deploy:local": "cd ../deployments/local && ./deploy-local.sh",
    "deploy:staging": "cd ../deployments/staging && ./deploy-staging.sh",
    "deploy:production": "cd ../deployments/production && ./deploy-production.sh"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "prettier": "^3.0.0",
    "eslint": "^8.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "packageManager": "bun@1.0.0",
  "license": "GPL-3.0",
  "authors": ["TinyCloud Team"]
}