# Staging Environment Configuration

# Server Details
STAGING_HOST=staging.openkey.com
STAGING_USER=deploy
STAGING_KEY_PATH=~/.ssh/openkey-staging.pem

# Container Registry
STAGING_REGISTRY=registry.openkey.com

# Database
DB_HOST=staging-db.openkey.com
DB_PORT=5432
DB_NAME=openkey_staging
DB_USER=openkey
DB_PASSWORD=changeme

# Redis
REDIS_URL=redis://staging-redis.openkey.com:6379

# Application
NODE_ENV=staging
API_URL=https://staging-api.openkey.com
FRONTEND_URL=https://staging.openkey.com

# Security
JWT_SECRET=your-staging-jwt-secret-here
ENCRYPTION_KEY=your-staging-encryption-key-here

# Email (for recovery)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your-sendgrid-api-key
EMAIL_FROM=noreply@staging.openkey.com

# Monitoring
SENTRY_DSN=https://xxx@sentry.io/staging
DATADOG_API_KEY=your-datadog-api-key

# Feature Flags
ENABLE_EMAIL_RECOVERY=true
ENABLE_MULTI_DEVICE=true
ENABLE_TEE_INTEGRATION=false