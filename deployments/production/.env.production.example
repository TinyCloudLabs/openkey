# Production Environment Configuration

# Server Details
PROD_HOST=prod1.openkey.com,prod2.openkey.com
PROD_USER=deploy
PROD_KEY_PATH=~/.ssh/openkey-production.pem

# Container Registry
PROD_REGISTRY=registry.openkey.com

# Database (Primary + Read Replicas)
DB_HOST_PRIMARY=prod-db-primary.openkey.com
DB_HOST_REPLICAS=prod-db-replica1.openkey.com,prod-db-replica2.openkey.com
DB_PORT=5432
DB_NAME=openkey_production
DB_USER=openkey
DB_PASSWORD=use-aws-secrets-manager
DB_SSL=require

# Redis Cluster
REDIS_CLUSTER=prod-redis-1.openkey.com:6379,prod-redis-2.openkey.com:6379,prod-redis-3.openkey.com:6379
REDIS_PASSWORD=use-aws-secrets-manager

# Application
NODE_ENV=production
API_URL=https://api.openkey.com
FRONTEND_URL=https://openkey.com

# Security (Use AWS Secrets Manager or similar)
JWT_SECRET=aws-secret://openkey/jwt-secret
ENCRYPTION_KEY=aws-secret://openkey/encryption-key
TEE_ATTESTATION_KEY=aws-secret://openkey/tee-attestation

# Email (Production)
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=aws-ses-user
SMTP_PASSWORD=aws-secret://openkey/ses-password
EMAIL_FROM=noreply@openkey.com

# CDN
CDN_URL=https://cdn.openkey.com
CLOUDFRONT_DISTRIBUTION_ID=E1234567890ABC

# Monitoring & Alerting
SENTRY_DSN=https://xxx@sentry.io/production
DATADOG_API_KEY=aws-secret://openkey/datadog-api-key
PAGERDUTY_INTEGRATION_KEY=aws-secret://openkey/pagerduty

# Feature Flags
ENABLE_EMAIL_RECOVERY=true
ENABLE_MULTI_DEVICE=true
ENABLE_TEE_INTEGRATION=true
ENABLE_RATE_LIMITING=true
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX_REQUESTS=100

# Backup Configuration
BACKUP_S3_BUCKET=openkey-backups-prod
BACKUP_RETENTION_DAYS=30

# Compliance
ENABLE_AUDIT_LOGGING=true
AUDIT_LOG_S3_BUCKET=openkey-audit-logs
GDPR_MODE=true