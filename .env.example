# Database
DATABASE_URL=postgresql://openkey:openkey@localhost:5432/openkey

# Ports
API_PORT=3001
WEB_PORT=5173
ADMIN_PORT=5174

# Service URLs (update these if you change ports)
API_URL=http://localhost:3001
WEB_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174
# VITE_API_URL - only needed in production (e.g. https://api.openkey.so)
# In dev, the Vite proxy handles /api routing to API_URL

# WebAuthn / Passkey
# Production: WEBAUTHN_RP_ID=openkey.so, WEBAUTHN_ORIGIN=https://openkey.so
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:5173

# Auth
BETTER_AUTH_SECRET=<generate-a-random-secret>
BETTER_AUTH_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# OAuth - Google
GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>

# TEE Mode
TEE_MODE=development
DEV_SEALING_KEY=<32-byte-hex-key-for-local-dev>

# Email (Resend)
RESEND_API_KEY=<your-resend-api-key>

# Admin
OPENKEY_API_URL=https://api.openkey.so
ADMIN_API_KEY=your-secret-key
