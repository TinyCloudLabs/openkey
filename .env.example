# Database (Neon)
DATABASE_URL=postgresql://user:password@host:5432/openkey

# WebAuthn / Passkey
# Production: WEBAUTHN_RP_ID=openkey.so, WEBAUTHN_ORIGIN=https://openkey.so
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:5173

# OAuth - Google
GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>

# TEE Mode
TEE_MODE=development
DEV_SEALING_KEY=<32-byte-hex-key-for-local-dev>

# Email (Resend)
RESEND_API_KEY=<your-resend-api-key>

# API
API_PORT=3001
CORS_ORIGIN=http://localhost:5173

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=

# registration secrets
OPENKEY_API_URL=https://api.openkey.so
ADMIN_API_KEY=your-secret-key
