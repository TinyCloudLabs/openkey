{
  "name": "openkey",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo dev",
    "dev:api": "turbo dev --filter @openkey/api",
    "dev:web": "turbo dev --filter @openkey/web",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:restart": "bun docker:down && bun docker:up",
    "docker:logs": "docker compose logs -f",
    "db:push": "bunx prisma db push --schema=./packages/db/prisma/schema.prisma",
    "db:push:prod": "dotenv -e .env.prod -- bunx prisma db push --schema=./packages/db/prisma/schema.prisma",
    "db:generate": "bunx prisma generate --schema=./packages/db/prisma/schema.prisma",
    "db:studio": "bunx prisma studio --schema=./packages/db/prisma/schema.prisma",
    "phala:env": "phala deploy --cvm-id $(phala cvms list --json | jq -r '.items[] | select(.cvmName == \"openkey-api\") | .appId' | sed 's/^/app_/') -c docker-compose.prod.yml -e .env.prod",
    "oauth:register": "bun run scripts/register-oauth-client.ts",
    "oauth:list": "bun run scripts/register-oauth-client.ts --list"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "tailwindcss": "^4.1.18",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "bun@1.1.0",
  "dependencies": {
    "@better-auth/cli": "1.5.0-beta.10",
    "@better-auth/oauth-provider": "1.5.0-beta.10",
    "@better-auth/passkey": "1.5.0-beta.10",
    "better-auth": "1.5.0-beta.10",
    "bits-ui": "^2.15.2",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "hono": "^4.11.3",
    "resend": "^6.6.0",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "viem": "^2.43.5"
  }
}
